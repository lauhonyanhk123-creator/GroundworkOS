# GroundworkOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API Keys

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret key — server-side only. Never expose to the browser.
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Mistral AI ────────────────────────────────────────────────────────────────
# Get from: console.mistral.ai → API Keys
# Only required for the AI assistant feature.

MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── SendGrid ──────────────────────────────────────────────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys
# Required for Send Invoice and Send Quote email delivery.

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=invoices@yourdomain.com

# ─── Xero ──────────────────────────────────────────────────────────────────────
# Get from: developer.xero.com → My Apps → OAuth 2.0 credentials
# Required for Xero accounting sync. Set XERO_REDIRECT_URI to match your app's
# callback URL configured in the Xero developer portal.

XERO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XERO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XERO_REDIRECT_URI=https://yourdomain.com/api/xero/callback

# ─── Optional integrations ─────────────────────────────────────────────────────
# Falls back to mock data if not set.

# Met Office API key — enables real weather risk in the schedule tool.
# Get from: datahub.metoffice.gov.uk
MET_OFFICE_API_KEY=

# HMRC CIS verification token — enables real CIS status checks.
# Get from: developer.service.hmrc.gov.uk
HMRC_ACCESS_TOKEN=
