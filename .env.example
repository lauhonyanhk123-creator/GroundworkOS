# =============================================================================
# GroundworkOS — environment variables
# =============================================================================
# This file documents every environment variable the app uses. Copy the values
# you need into your own environment (a systemd EnvironmentFile, a shell export,
# or a .env file) — do NOT commit real secrets.
#
# There are two very different ways to run GroundworkOS:
#
#   • On Replit  — object storage and Clerk auth are provided automatically by
#                  the Replit platform. You do not normally set these yourself.
#
#   • Self-hosted (e.g. Oracle Cloud) — you provide your own database, your own
#                  S3-compatible object storage, and your own Clerk account.
#                  See DEPLOYMENT-ORACLE.md for the full walkthrough.
#
# Each variable below is tagged:
#   [core]      needed everywhere
#   [replit]    set automatically on Replit — only relevant there
#   [selfhost]  set these when self-hosting off Replit
#   [optional]  only if you use that feature
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# [core] Port the API server listens on. On a self-hosted VM, 8080 is fine
# (Nginx proxies to it). Also required when BUILDING the frontend (any value).
PORT=8080

# [core] Node environment. Use "production" when self-hosting.
NODE_ENV=production

# [optional] Log verbosity: trace|debug|info|warn|error. Defaults to info.
# LOG_LEVEL=info


# -----------------------------------------------------------------------------
# Database (PostgreSQL) — [core]
# -----------------------------------------------------------------------------
# Standard Postgres connection string. On Replit this is provided for you.
# Self-hosting example (local Postgres on the same VM):
DATABASE_URL=postgresql://groundworkos:CHANGE_ME@localhost:5432/groundworkos


# -----------------------------------------------------------------------------
# Authentication (Clerk)
# -----------------------------------------------------------------------------
# Backend keys (from your Clerk dashboard → API Keys).
CLERK_PUBLISHABLE_KEY=pk_test_xxx_or_pk_live_xxx   # [core]
CLERK_SECRET_KEY=sk_test_xxx_or_sk_live_xxx        # [core]

# [selfhost] Set to "true" ONLY when running off Replit against your own Clerk
# account. This turns OFF the Replit Clerk proxy and makes the app use the keys
# above directly. Leave UNSET (or "false") on Replit.
# CLERK_STANDALONE=true

# [selfhost] Public URL of your deployed app, e.g. https://app.yourdomain.com
# Used for Clerk's authorizedParties check and for client-portal links.
# APP_URL=https://app.yourdomain.com

# --- Frontend (build-time) Clerk vars ---
# These are baked into the frontend at BUILD time (they must be present when you
# run the frontend build; they are NOT read at runtime).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx_or_pk_live_xxx   # [core]

# [replit] The Replit Clerk proxy URL. On Replit this is set automatically.
# When self-hosting with your own Clerk account, LEAVE THIS UNSET — that is what
# tells the frontend to talk to Clerk directly instead of via the Replit proxy.
# VITE_CLERK_PROXY_URL=

# [selfhost] Base path the frontend is served under. Required at build time.
# Use "/" when the app is served at the domain root (the normal self-host case).
BASE_PATH=/


# -----------------------------------------------------------------------------
# Object storage
# -----------------------------------------------------------------------------
# Which storage backend to use:
#   "replit" (default) — Google Cloud Storage via the Replit sidecar (Replit only)
#   "s3"               — any S3-compatible store (Oracle Object Storage, AWS S3, MinIO)
STORAGE_DRIVER=replit

# --- [replit] Replit object storage (only when STORAGE_DRIVER=replit) ---
# These are provided automatically on Replit; you do not set them by hand.
# PRIVATE_OBJECT_DIR=/your-bucket/.private
# PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public

# --- [selfhost] S3-compatible object storage (only when STORAGE_DRIVER=s3) ---
# For Oracle Cloud Object Storage, the endpoint looks like:
#   https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
S3_ENDPOINT=https://NAMESPACE.compat.objectstorage.uk-london-1.oraclecloud.com
S3_REGION=uk-london-1
S3_BUCKET=groundworkos-files
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
# Oracle requires path-style addressing. Leave "true" unless your provider needs
# virtual-hosted-style (then set "false").
S3_FORCE_PATH_STYLE=true
# Key prefix under which public assets are stored (optional). Default: public/
# S3_PUBLIC_PREFIX=public/


# -----------------------------------------------------------------------------
# Email (Resend) — [optional]
# -----------------------------------------------------------------------------
# Only needed if you send emails (e.g. invoices) from the app.
# RESEND_API_KEY=re_xxx


# -----------------------------------------------------------------------------
# Accounting integrations — [optional]
# -----------------------------------------------------------------------------
# Only set the provider(s) you actually connect. Each REDIRECT_URI must point at
# YOUR deployed domain, e.g. https://app.yourdomain.com/api/xero/callback, and
# must be registered in that provider's developer dashboard.

# Xero
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=https://app.yourdomain.com/api/xero/callback

# QuickBooks
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=https://app.yourdomain.com/api/quickbooks/callback

# Sage
# SAGE_CLIENT_ID=
# SAGE_CLIENT_SECRET=
# SAGE_REDIRECT_URI=https://app.yourdomain.com/api/sage/callback

# FreeAgent
# FREEAGENT_CLIENT_ID=
# FREEAGENT_CLIENT_SECRET=
# FREEAGENT_REDIRECT_URI=https://app.yourdomain.com/api/freeagent/callback
